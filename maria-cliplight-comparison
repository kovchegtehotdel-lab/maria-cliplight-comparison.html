            font-weight: 400;
            color: #2c3e50;
        }
        .subhead {
            color: #546e7a;
            margin-bottom: 32px;
            padding-bottom: 16px;
            border-bottom: 2px solid #e9ecf2;
        }
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin: 24px 0;
        }
        .card {
            background: #f9fafc;
            border-radius: 28px;
            padding: 24px;
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.02), 0 6px 12px rgba(0,0,0,0.02);
            border: 1px solid #e6ecf2;
        }
        .card h2 {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            font-size: 1.5rem;
            margin-top: 0;
            margin-bottom: 20px;
        }
        .badge {
            background: #0a2540;
            color: white;
            font-size: 0.75rem;
            padding: 4px 12px;
            border-radius: 40px;
        }
        .row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px dashed #d4dfe7;
        }
        .row:last-child {
            border-bottom: none;
        }
        .label {
            color: #3a4f5f;
            font-weight: 500;
        }
        .value {
            font-weight: 600;
            color: #0a2540;
               }
        .highlight {
            background: #e0ffe0;
            padding: 20px;
            border-radius: 20px;
            margin: 28px 0 16px;
            border-left: 6px solid #2ecc71;
        }
        .highlight-red {
            background: #ffeaea;
            border-left-color: #e74c3c;
        }
        .flex-table {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .table-header {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            font-weight: 700;
            color: #2c3e50;
            padding: 8px 0;
            border-bottom: 2px solid #ccc;
        }
        .table-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            padding: 8px 0;
            border-bottom: 1px solid #e0e7ed;
        }
        .note {
            background: #fef9e7;
            border-radius: 20px;
            padding: 18px;
            font-size: 0.95rem;
            margin: 24px 0;
            color: #7d5d23;
        }
        .footer-note {
            text-align: right;
            color: #7a8d9b;
            font-size: 0.9rem;
            margin-top: 32px;
            border-top: 1px solid #e2e8f0;
            padding-top: 20px;
        }
        .btn-copy {
            background: #0a2540;
            color: white;
            border: none;
            padding: 8px 24px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
        }
        @media (max-width: 700px) {
            .grid-2 { grid-template-columns: 1fr; }
        }
    </style>
